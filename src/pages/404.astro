---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SiteHeader from '~/components/SiteHeader.astro';
import SiteFooter from '~/components/SiteFooter.astro';
---
<BaseLayout title="Page not found">
  <SiteHeader />
  <main class="mx-auto max-w-2xl px-4 py-20 text-center">
    <h1 class="!mt-0 text-6xl font-bold" style="color: var(--color-accent);">404</h1>
    <p class="mt-2 text-lg" style="color: var(--color-fg-muted);">
      That page doesn't exist (or has moved).
    </p>
    <p class="mt-6">
      <a href="/">Back to the homepage</a> &nbsp;·&nbsp;
      <a href="/what-is/">Browse the archive</a>
    </p>
  </main>
  <SiteFooter />
</BaseLayout>
