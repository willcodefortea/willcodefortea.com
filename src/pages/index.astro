---
const target = '/about/';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting…</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={new URL(target, Astro.site).toString()} />
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p><a href={target}>Continue to {target}</a></p>
  </body>
</html>
