---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '~/components/SiteHeader.astro';
import SiteFooter from '~/components/SiteFooter.astro';
import OverlayHeader from '~/components/OverlayHeader.astro';
import ImageZoom from '~/components/ImageZoom.astro';

interface Props {
  title: string;
  date?: Date;
  excerpt?: string;
  overlayImage?: string;
  overlayFilter?: string | number;
}
const { title, date, excerpt, overlayImage, overlayFilter } = Astro.props;

const formattedDate = date
  ? new Intl.DateTimeFormat('en-GB', { dateStyle: 'long' }).format(date)
  : undefined;
---
<BaseLayout title={title} description={excerpt} ogImage={overlayImage}>
  <SiteHeader />
  {overlayImage && (
    <OverlayHeader title={title} date={formattedDate} image={overlayImage} filter={overlayFilter} />
  )}
  <main class="mx-auto max-w-3xl px-4 py-10">
    {!overlayImage && (
      <header class="mb-8">
        <h1 class="!mt-0">{title}</h1>
        {formattedDate && <p class="text-sm" style="color: var(--color-fg-muted);">{formattedDate}</p>}
      </header>
    )}
    <article class="prose">
      <slot />
    </article>
  </main>
  <SiteFooter />
  <ImageZoom />
</BaseLayout>
